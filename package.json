{
  "name": "erpindo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "smoke": "node apps/api/scripts/smoke.mjs",
    "seed:demo": "node scripts/seed-demo.mjs",
    "dev:api": "pnpm --filter @erpindo/api dev",
    "dev:web": "pnpm --filter @erpindo/web dev",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,mjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,mjs}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "playwright-core": "^1.61.1",
    "prettier": "^3.3.0"
  }
}
