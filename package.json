{
  "name": "erpindo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "smoke": "node apps/api/scripts/smoke.mjs",
    "seed:demo": "node scripts/seed-demo.mjs",
    "dev:api": "pnpm --filter @erpindo/api dev",
    "dev:web": "pnpm --filter @erpindo/web dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,mjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,mjs}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "playwright-core": "^1.61.1",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.64.0"
  }
}
